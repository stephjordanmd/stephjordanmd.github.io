              {f} <span style={{opacity:0.65}}>({cnt[f]})</span>
            </button>
          );
        })}
        <div style={{marginLeft:"auto",display:"flex",gap:"0.4rem",alignItems:"center"}}>
          <span style={{fontSize:"0.62rem",color:"#7a9bbf",textTransform:"uppercase",letterSpacing:"0.1em"}}>Sort:</span>
          {[["rank","# Rank"],["rev","Revenue"],["niat","NIAT"],["margin","Margin"]].map(([k,l])=>(
            <button key={k} onClick={()=>setSortBy(k)}
              style={{background:sortBy===k?"#1a3a6b":"transparent",color:sortBy===k?"#c9a84c":"#7a9bbf",
                      border:`1px solid ${sortBy===k?"#c9a84c":"#1e3a5f"}`,borderRadius:"4px",
                      padding:"0.18rem 0.55rem",cursor:"pointer",fontSize:"0.68rem"}}>
              {l}
            </button>
          ))}
        </div>
      </div>

      {/* Table */}
      <div style={{overflowX:"auto",padding:"0.75rem 1.5rem 2rem"}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:"0.72rem",whiteSpace:"nowrap"}}>
          <thead>
            <tr style={{background:"#101e30",borderBottom:`2px solid ${curTab.color}`}}>
              <th style={{padding:"0.45rem 0.5rem",color:curTab.color,textAlign:"center",width:"3rem",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.06em"}}>#</th>
              <th style={{padding:"0.45rem 0.5rem",color:curTab.color,textAlign:"center",width:"4.5rem",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.06em"}}>Code</th>
              <th style={{padding:"0.45rem 0.5rem",color:curTab.color,textAlign:"center",width:"6rem",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.06em"}}>Status</th>
              {tab==="overview" && <>
                <th style={{padding:"0.45rem 0.5rem",color:curTab.color,textAlign:"left",width:"11rem",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.06em"}}>Industry {editMode&&"✏"}</th>
                <th style={{padding:"0.45rem 0.5rem",color:curTab.color,textAlign:"center",width:"7rem",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.06em"}}>Yr Incorp {editMode&&"✏"}</th>
                <th style={{padding:"0.45rem 0.5rem",color:curTab.color,textAlign:"center",width:"5rem",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.06em"}}>Age</th>
                <th style={{padding:"0.45rem 0.5rem",color:curTab.color,textAlign:"center",width:"6rem",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.06em"}}>Jordan % {editMode&&"✏"}</th>
                <th style={{padding:"0.45rem 0.5rem",color:curTab.color,textAlign:"center",width:"6rem",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.06em"}}>JV % {editMode&&"✏"}</th>
              </>}
              {tab!=="overview" && editMode && FIN_FIELDS[tab] && FIN_FIELDS[tab].map(f=>(
                <th key={f.key} style={{padding:"0.45rem 0.5rem",color:"#c9a84c",textAlign:"center",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.04em",background:"rgba(201,168,76,0.08)",borderBottom:`2px solid #c9a84c`}}>
                  {f.label.split("(")[0].trim()} ✏
                </th>
              ))}
              {cols.map(col=>(
                <th key={col.key} style={{padding:"0.45rem 0.5rem",color:curTab.color,textAlign:"right",fontSize:"0.62rem",textTransform:"uppercase",letterSpacing:"0.04em"}}>{col.label}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {filtered.map((c,i)=>{
              const hs=HEALTH_S[c.health];
              const rowBg=i%2===0?"rgba(255,255,255,0.015)":"rgba(255,255,255,0.03)";
              const icuTint=c.health==="ICU"?"rgba(153,27,27,0.06)":rowBg;
              return (
                <tr key={c.code} style={{background:icuTint,borderBottom:"1px solid rgba(255,255,255,0.03)"}}>
                  <td style={{padding:"0.4rem 0.5rem",textAlign:"center",color:"#4a6a8a"}}>{c.num}</td>
                  <td style={{padding:"0.4rem 0.5rem",textAlign:"center",fontWeight:"bold",color:"#f5e6c8",letterSpacing:"0.04em"}}>{c.code}</td>
                  <td style={{padding:"0.3rem 0.4rem",textAlign:"center"}}>
                    <span style={{background:hs.bg,color:hs.text,border:`1px solid ${hs.border}`,borderRadius:"4px",padding:"0.12rem 0.45rem",fontSize:"0.62rem",fontWeight:"bold"}}>
                      {c.health}
                    </span>
                  </td>
                  {tab==="overview" && <>
                    <td style={{padding:"0.2rem 0.4rem",textAlign:"left"}}>
                      {editMode
                        ? <input value={c.industry} onChange={e=>setB(c.code,"industry",e.target.value)}
                            placeholder="Enter industry…"
                            style={{width:"100%",background:"rgba(201,168,76,0.1)",border:"1px solid #c9a84c",borderRadius:"3px",color:"#f5e6c8",padding:"0.12rem 0.35rem",fontSize:"0.7rem",outline:"none",fontFamily:"inherit"}}/>
                        : <span style={{color:c.industry?"#e8dcc8":"#3d5a78"}}>{c.industry||"—"}</span>}
                    </td>
                    <td style={{padding:"0.2rem 0.4rem",textAlign:"center"}}>
                      {editMode
                        ? <input value={c.yearIncorp} onChange={e=>setB(c.code,"yearIncorp",e.target.value)}
                            placeholder="e.g. 1998" type="number" min="1950" max="2025"
                            style={{width:"100%",background:"rgba(201,168,76,0.1)",border:"1px solid #c9a84c",borderRadius:"3px",color:"#f5e6c8",padding:"0.12rem 0.35rem",fontSize:"0.7rem",outline:"none",fontFamily:"inherit",textAlign:"center"}}/>
                        : <span style={{color:c.yearIncorp?"#e8dcc8":"#3d5a78"}}>{c.yearIncorp||"—"}</span>}
                    </td>
                    <td style={{padding:"0.4rem 0.5rem",textAlign:"center",color:c.yrsActive?"#9db4cc":"#3d5a78"}}>
                      {c.yrsActive!==null?`${c.yrsActive}y`:"—"}
                    </td>
                    <td style={{padding:"0.2rem 0.4rem",textAlign:"center"}}>
                      {editMode
                        ? <input value={c.jordanPct} onChange={e=>setB(c.code,"jordanPct",e.target.value)}
                            placeholder="e.g. 60" type="number" min="0" max="100"
                            style={{width:"100%",background:"rgba(201,168,76,0.1)",border:"1px solid #c9a84c",borderRadius:"3px",color:"#f5e6c8",padding:"0.12rem 0.35rem",fontSize:"0.7rem",outline:"none",fontFamily:"inherit",textAlign:"center"}}/>
                        : <span style={{color:c.jordanPct?"#c9a84c":"#3d5a78"}}>{c.jordanPct?`${c.jordanPct}%`:"—"}</span>}
                    </td>
                    <td style={{padding:"0.2rem 0.4rem",textAlign:"center"}}>
                      {editMode
                        ? <input value={c.jvPct} onChange={e=>setB(c.code,"jvPct",e.target.value)}
                            placeholder="e.g. 100" type="number" min="0" max="100"
                            style={{width:"100%",background:"rgba(201,168,76,0.1)",border:"1px solid #c9a84c",borderRadius:"3px",color:"#f5e6c8",padding:"0.12rem 0.35rem",fontSize:"0.7rem",outline:"none",fontFamily:"inherit",textAlign:"center"}}/>
                        : <span style={{color:c.jvPct?"#9db4cc":"#3d5a78"}}>{c.jvPct?`${c.jvPct}%`:"—"}</span>}
                    </td>
                  </>}
                  {tab!=="overview" && editMode && FIN_FIELDS[tab] && FIN_FIELDS[tab].map(f=>(
                    <td key={f.key} style={{padding:"0.2rem 0.35rem",background:"rgba(201,168,76,0.04)"}}>
                      <input value={fin[c.code][f.key]} onChange={e=>setF(c.code,f.key,e.target.value)}
                        placeholder={f.ph} type="number"
                        style={{width:"100%",background:"rgba(201,168,76,0.1)",border:"1px solid rgba(201,168,76,0.5)",borderRadius:"3px",color:"#f5e6c8",padding:"0.12rem 0.35rem",fontSize:"0.7rem",outline:"none",fontFamily:"inherit",textAlign:"right"}}/>
                    </td>
                  ))}
                  {cols.map(col=>{
                    const val = c[col.key];
                    const colorStyle = col.ratioKey
                      ? getRatioColor(col.ratioKey, val)
                      : { bg:"transparent", text: typeof col.color==="function" ? col.color(val) : (col.color||"#e8dcc8") };
                    return (
                      <td key={col.key} style={{padding:"0.4rem 0.5rem",textAlign:"right",background:colorStyle.bg,color:colorStyle.text}}>
                        {col.fmt(val)}
                      </td>
                    );
                  })}
                </tr>
              );
            })}
          </tbody>
          <tfoot>
            <tr style={{background:"#0c1929",borderTop:`2px solid ${curTab.color}`}}>
              <td colSpan={tab==="overview"?11:3} style={{padding:"0.45rem 0.5rem",color:curTab.color,fontWeight:"bold",fontSize:"0.65rem",letterSpacing:"0.05em",textTransform:"uppercase"}}>
                Portfolio Totals ({filtered.length})
              </td>
              {tab==="overview" && cols.map(col=>{
                const vals = filtered.map(c=>c[col.key]).filter(v=>v!==null&&!isNaN(v));
                const sum = vals.reduce((s,v)=>s+v,0);
                const disp = col.key==="pctPaced" ? "—" : col.key==="q1Margin" ? fmtP(filtered.reduce((s,c)=>s+c.niYtd,0)/(filtered.reduce((s,c)=>s+c.rev,0)*3)) : col.fmt(sum);
                return <td key={col.key} style={{padding:"0.45rem 0.5rem",textAlign:"right",color:"#f5e6c8",fontWeight:"bold"}}>{disp}</td>;
              })}
              {tab!=="overview" && cols.map(col=>(
                <td key={col.key} style={{padding:"0.45rem 0.5rem",textAlign:"right",color:"#5a7a9a"}}>—</td>
              ))}
            </tr>
          </tfoot>
        </table>
      </div>

      <div style={{borderTop:"1px solid #1a3050",padding:"0.6rem 1.5rem",fontSize:"0.6rem",color:"#3d5a78",display:"flex",justifyContent:"space-between",flexWrap:"wrap",gap:"0.5rem"}}>
        <span>Asialink Group · Jordan Family Holdings · March 2026</span>
        <span>Healthy = NIAT ≥ ₱1M + Q1 margin ≥ 1.5% · Watch = below thresholds · ICU = Negative NIAT · Benchmarks are general guidelines; adjust for industry context</span>
      </div>
    </div>
  );
}
