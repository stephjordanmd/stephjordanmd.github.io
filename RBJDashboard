const getRatioColor = (key, val) => {
  if (val === null || isNaN(val)) return { bg:"transparent", text:"#3d5a78" };
  const b = BENCHMARKS[key];
  if (!b) return { bg:"transparent", text:"#e8dcc8" };
  if (b.dir === "high") {
    if (val >= b.high) return { bg:"rgba(21,128,61,0.25)", text:"#86efac" };
    if (val >= b.low)  return { bg:"rgba(161,98,7,0.2)",  text:"#fde68a" };
    return { bg:"rgba(153,27,27,0.25)", text:"#fca5a5" };
  } else {
    if (val <= b.high) return { bg:"rgba(21,128,61,0.25)", text:"#86efac" };
    if (val <= b.low)  return { bg:"rgba(161,98,7,0.2)",  text:"#fde68a" };
    return { bg:"rgba(153,27,27,0.25)", text:"#fca5a5" };
  }
};

