};
const initFin = () => {
  const o = {};
  RAW.forEach(([,code]) => {
    o[code] = { gp:"",ebit:"",intExp:"",cash:"",sti:"",ar:"",inv:"",ca:"",ta:"",cl:"",debt:"",equity:"" };
  });
  return o;
};

const getHealth = (niat, rev, niYtd) => {
  if (niat < 0) return "ICU";
  if (niat < 1 || niYtd/(rev*3) < 0.015) return "Watch";
  return "Healthy";
};

const n = (v) => v !== "" && v !== null && v !== undefined && !isNaN(parseFloat(v)) ? parseFloat(v) : null;
const fmtN = (v, dec=3) => {
  if (v === null || v === undefined || isNaN(v)) return "—";
  const abs = Math.abs(v), s = abs.toFixed(dec).replace(/\B(?=(\d{3})+(?!\d))/g,",");
  return v < 0 ? `(${s})` : s;
};
const fmtP = (v, dec=1) => v === null || isNaN(v) ? "—" : `${(v*100).toFixed(dec)}%`;
const fmtX = (v, dec=2) => v === null || isNaN(v) ? "—" : `${v.toFixed(dec)}x`;

const computeRatios = (rev, niYtd, niat, fd) => {
  const annR = rev * 12, q1R = rev * 3;
  const gp=n(fd.gp), ebit=n(fd.ebit), intE=n(fd.intExp), cash=n(fd.cash),
        sti=n(fd.sti), ar=n(fd.ar), inv=n(fd.inv), ca=n(fd.ca), ta=n(fd.ta),
        cl=n(fd.cl), debt=n(fd.debt), eq=n(fd.equity);
  return {
    grossMargin:     gp!==null && annR ? gp/annR : null,
    netMarginTTM:    annR ? niat/annR : null,
    netMarginQ1:     q1R ? niYtd/q1R : null,
    roa:             ta ? niat/ta : null,
    roe:             eq ? niat/eq : null,
    currentRatio:    ca!==null && cl ? ca/cl : null,
    quickRatio:      ca!==null && inv!==null && cl ? (ca-inv)/cl : null,
    acidTest:        cash!==null && sti!==null && ar!==null && cl ? (cash+sti+ar)/cl : null,
    cashRatio:       cash!==null && cl ? cash/cl : null,
    debtToEquity:    debt!==null && eq ? debt/eq : null,
    intCoverage:     ebit!==null && intE ? ebit/intE : null,
    assetTurnover:   ta ? annR/ta : null,
    recvTurnover:    ar ? annR/ar : null,
    invTurnover:     inv ? annR/inv : null,
  };
};

